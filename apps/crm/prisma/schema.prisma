generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  phone           String?
  city            String?
  state           String?
  channel_pref    String   @default("EMAIL") // EMAIL, WHATSAPP, SMS
  lifecycle_stage String   @default("NEW") // NEW, ACTIVE, AT_RISK, DORMANT
  rfm_score       String? // HIGH_VALUE, MID_TIER, LOW_VALUE
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  orders         Order[]
  communications Communication[]
}

model Order {
  id           String   @id @default(cuid())
  customer_id  String
  amount       Float
  product_name String
  created_at   DateTime @default(now())

  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  
  attributed_campaign_id String?
  attributed_campaign    Campaign? @relation(fields: [attributed_campaign_id], references: [id], onDelete: SetNull)
}

model Segment {
  id          String   @id @default(cuid())
  name        String
  filter_json Json // Stores the structured JSON filter generated by AI
  is_dynamic  Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  campaigns Campaign[]
}

model Campaign {
  id               String    @id @default(cuid())
  name             String
  segment_id       String
  channel          String // EMAIL, WHATSAPP, SMS
  message_template String
  status           String    @default("DRAFT") // DRAFT, SENDING, SENT, FAILED
  sent_at          DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  segment        Segment         @relation(fields: [segment_id], references: [id])
  communications Communication[]
  attributed_orders Order[]
}

model Communication {
  id           String    @id @default(cuid())
  campaign_id  String
  customer_id  String
  status       String    @default("PENDING") // PENDING, SENT, DELIVERED, OPENED, READ, CLICKED, FAILED
  sent_at      DateTime?
  delivered_at DateTime?
  opened_at    DateTime?
  clicked_at   DateTime?
  failed_at    DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  campaign Campaign    @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  customer Customer    @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  events   CommEvent[]
}

model CommEvent {
  id               String   @id @default(cuid())
  communication_id String
  event_type       String // DELIVERED, OPENED, CLICKED, FAILED
  received_at      DateTime @default(now())

  communication Communication @relation(fields: [communication_id], references: [id], onDelete: Cascade)

  // Unique composite index for idempotency
  @@unique([communication_id, event_type])
}

model Settings {
  id                    String   @id @default("singleton")
  high_value_min_spend  Float    @default(10000.0)
  high_value_min_orders Int      @default(5)
  mid_tier_min_spend    Float    @default(3000.0)
  mid_tier_min_orders   Int      @default(2)
  at_risk_days          Int      @default(60)
  dormant_days          Int      @default(120)
  updated_at            DateTime @updatedAt
}

model Workflow {
  id         String   @id @default(cuid())
  name       String
  status     String   @default("DRAFT") // DRAFT, ACTIVE, PAUSED
  nodes_json Json     // The array of configured nodes
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}
